#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${HOME}/.local/state/tahoe"
STATE_FILE="$STATE_DIR/last-animation-day"
TODAY="$(date +%F)"
mkdir -p "$STATE_DIR"

# Run once per day per user to avoid annoyance.
if [[ -f "$STATE_FILE" ]] && [[ "$(cat "$STATE_FILE" 2>/dev/null || true)" == "$TODAY" ]]; then
  exit 0
fi

if command -v zenity >/dev/null 2>&1; then
  {
    for i in 0 8 16 24 32 40 48 56 64 72 80 88 96 100; do
      echo "$i"
      echo "# Preparing Tahoe desktop..."
      sleep 0.12
    done
  } | zenity --progress \
      --title="Tahoe Startup" \
      --text="Preparing Tahoe desktop..." \
      --percentage=0 \
      --auto-close \
      --width=420 || true
fi

echo "$TODAY" > "$STATE_FILE"
